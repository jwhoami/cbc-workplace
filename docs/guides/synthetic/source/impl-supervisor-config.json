    "autostart=true",
    "autorestart=true",
    "user=www-data",
    "numprocs=2",
    "redirect_stderr=true",
    "stdout_logfile=/var/log/supervisor/cbc-workplace-queue.log",
    "stopwaitsecs=3600",
    "",
    "[program:cbc-workplace-scheduler]",
    "command=php /var/www/cbc-workplace/artisan schedule:work",
    "autostart=true",
    "autorestart=true",
    "user=www-data",
    "numprocs=1",
    "redirect_stderr=true",
    "stdout_logfile=/var/log/supervisor/cbc-workplace-scheduler.log"
